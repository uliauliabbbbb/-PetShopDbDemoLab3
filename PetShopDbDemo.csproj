    <RootNamespace>PetShopDbDemo</RootNamespace>
    <AssemblyName>PetShopDbDemo</AssemblyName>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Data.Odbc" Version="8.0.0" />
